# Aplatit les node_modules (deps transitives résolvables au runtime).
# Requis pour le déploiement Railway/Nixpacks d'un monorepo pnpm :
# sans ça, les dépendances transitives (ex. express via @nestjs/platform-express)
# ne sont pas trouvées par `node dist/main.js`.
node-linker=hoisted
# Une seule instance des paquets peer-dépendus (ex. @nestjs/core, @nestjs/common) :
# sinon le hoisting crée deux copies → la DI NestJS échoue à matcher Reflector/HttpException
# entre @nestjs/throttler et l'app (guard de débit cassé).
dedupe-peer-dependents=true
# Hoist explicite des paquets NestJS au root → une seule copie partagée par l'app et
# @nestjs/throttler (résolution DI cohérente de Reflector).
public-hoist-pattern[]=@nestjs/*
public-hoist-pattern[]=reflect-metadata
