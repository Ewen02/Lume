// Configuration API de Lume — TEMPLATE versionné (sans secret).
//
// Copie ce fichier en `Secrets.xcconfig` (non versionné) et renseigne les vraies valeurs,
// puis régénère le projet : `pnpm ios:generate`.
//
//   cp Lume/Secrets.xcconfig.example Lume/Secrets.xcconfig
//
// Le jeton doit être identique à API_TOKEN dans les variables d'env Railway du serveur.

// Backend déployé (HTTPS public). En local : http:/$()/localhost:3000
LUME_API_BASE_URL = https:/$()/lumeserver-production.up.railway.app

// Jeton Bearer attendu par le serveur. Laisse `change-me` si tu n'as pas encore de backend.
LUME_API_TOKEN = change-me
