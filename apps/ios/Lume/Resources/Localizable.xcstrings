          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Values are estimated by AI: check them before adding."
          }
        }
      }
    },
    "Lume fournit des estimations à titre informatif et ne remplace pas un avis médical.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lume fournit des estimations à titre informatif et ne remplace pas un avis médical."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lume provides estimates for informational purposes and is not a substitute for medical advice."
          }
        }
      }
    },
    "En continuant, tu acceptes nos conditions et notre politique de confidentialité.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En continuant, tu acceptes nos conditions et notre politique de confidentialité."
          }
        },
