PORT=3000
# Jeton statique attendu dans l'en-tête Authorization: Bearer <token>
API_TOKEN=change-me

# --- Fournisseurs ---
# Sans ANTHROPIC_API_KEY : /analyze renvoie un repas de démonstration.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Sans USDA_API_KEY : résolution macros sur une petite table locale (7 aliments).
USDA_API_KEY=
# Open Food Facts (code-barres) : aucune clé requise.
